# OCI API signing-key credentials
OCI_USER_OCID=
OCI_TENANCY_OCID=
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=/home/ubuntu/.oci/oci_api_key.pem
OCI_REGION=ap-hyderabad-1

# Target resources
COMPARTMENT_OCID=
SUBNET_OCID=
IMAGE_OCID=
AD=ap-hyderabad-1-ad-1
SSH_PUBLIC_KEY=
INSTANCE_NAME=Rahul-ARM

# Ampere A1 configuration (only VM.Standard.A1.Flex is accepted)
SHAPE=VM.Standard.A1.Flex
OCPUS=2
MEMORY_IN_GBS=12
BOOT_VOLUME_SIZE_IN_GBS=100
RETRY_INTERVAL=60000
# DEFAULT_RETRY_MS supersedes RETRY_INTERVAL; RETRY_INTERVAL remains supported for compatibility.
DEFAULT_RETRY_MS=60000
RETRY_429_FIRST_MS=120000
RETRY_429_SECOND_MS=180000
RETRY_429_MAX_MS=300000

# Optional Telegram notifications (credentials are never logged)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STATUS_ENABLED=true
TELEGRAM_STATUS_INTERVAL_MINUTES=60
